{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'docker:enableMajor',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':automergeDigest',
    ':automergeBranch',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prIgnoreNotification',
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Update _VERSION variables in Dockerfiles',
      fileMatch: [
        '/(^|/|\\.)Dockerfile$/',
        '/(^|/)Dockerfile\\.[^/]*$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-]+?)(?:\\s+depName=(?<depName>[^\\s]+?))?(?:\\s+packageName=(?<packageName>[^\\s]+?))?(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\n(?:ENV|ARG)\\s+(?:[A-Z_]*_)?VERSION=(?<currentValue>[^\\s]+)',
      ],
    },
  ],
  packageRules: [
    {
      description: 'Auto-update config.yaml and CHANGELOG.md for add-on dependencies',
      matchManagers: ['regex'],
      matchFileNames: ['**/Dockerfile'],
      postUpgradeTasks: {
        commands: [
          'ADDON_DIR=$(dirname {{{packageFileDir}}}/{{{packageFile}}}) && sed -i "s/^version: \\"v[0-9]\\+\\.[0-9]\\+\\.[0-9]\\+\\(-[0-9]\\+\\)\\?\\"/version: \\"v{{{newValue}}}-1\\"/" "$ADDON_DIR/config.yaml"',
          'ADDON_DIR=$(dirname {{{packageFileDir}}}/{{{packageFile}}}) && sed -i "1i## {{{newValue}}}-1\\n\\n- Update {{{depName}}} to {{{newValue}}}\\n" "$ADDON_DIR/CHANGELOG.md"',
        ],
        fileFilters: ['**/config.yaml', '**/CHANGELOG.md'],
        executionMode: 'branch',
      },
    },
  ],
}
